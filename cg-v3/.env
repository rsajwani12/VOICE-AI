# ========================================================
# Common Ground — environment configuration
# ========================================================
# Copy this file to .env and fill in real values.
# Never commit .env.

# --- Gradium (voice) ---
# Get at https://app.gradium.ai/ — keys start with "gd_"
GRADIUM_API_KEY=gsk_73418e9a20162190ed7bb5bc4d69e20267f60eb9be414d801b7aae25b83774f3

# After cloning Patti's voice via the Gradium Studio, paste the voice_id here.
# See https://docs.gradium.ai/guides/voices/custom-voices
GRADIUM_CUSTOM_VOICE_ID=

# If no custom voice is cloned yet, fall back to a flagship voice.
# Default: Selene (female, calm). Browse more at docs.gradium.ai/guides/voices
GRADIUM_FALLBACK_VOICE_ID=YTpq7expH9539ERJ

# --- Thymia Sentinel (biomarkers + policy-driven actions) ---
# Get from Thymia via support@thymia.ai
THYMIA_API_KEY=O6pZETrIUx50oJWVdhVpu8r0S9eus8WU3PgQBX86

# Pre-configured policy names agreed with Thymia for your use case.
# Start with the demo policy; replace with custom ones Thymia configures for you.
THYMIA_POLICIES=demo_wellbeing_awareness

# Biomarker models to enable (helios = general, apollo = vocal, psyche = affect)
THYMIA_BIOMARKERS=helios,apollo

# --- Claude (intelligence / voice agent brain) ---
ANTHROPIC_API_KEY=

# --- LiveKit (meeting transport) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Behaviour ---
# Set to 1 before all keys are confirmed; 0 for live integration mode
USE_MOCK=1

# Server
HOST=0.0.0.0
PORT=8000
